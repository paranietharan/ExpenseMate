# RabbitMQ Connection Configuration
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=RabbitMQPassword@1234

# Gmail SMTP Configuration
# Set these to enable real email dispatching via Gmail.
# If SMTP_USER and SMTP_PASS are omitted, the service will fall back to printing
# the fully-rendered HTML email templates inside a mock outbox log on the console.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@expensemate.com
